# Copy to .env.local (gitignored). Production secrets live in Railway/Vercel.

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/homefit
DATABASE_USER=homefit
DATABASE_PASSWORD=homefit

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-64-random-bytes
AES_ENCRYPTION_KEY=change-me-32-random-bytes
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
KAKAO_OAUTH_CLIENT_ID=
KAKAO_OAUTH_CLIENT_SECRET=

# External data
PUBLIC_DATA_API_KEY=
MOLIT_API_KEY=
KAKAO_REST_API_KEY=
KAKAO_JS_KEY=
KAKAO_NATIVE_APP_KEY=
ODSAY_API_KEY=
VWORLD_API_KEY=

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_KAKAO_JS_KEY=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me

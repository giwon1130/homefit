{
  "expo": {
    "name": "homefit",
    "slug": "homefit",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "homefit",
    "platforms": [
      "ios",
      "android"
    ],
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fafafa"
    },
    "ios": {
      "bundleIdentifier": "app.homefit.mobile",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.homefit.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563eb"
        }
      ],
      "expo-apple-authentication",
      "@sentry/react-native/expo"
    ],
    "notification": {
      "iosDisplayInForeground": true
    },
    "extra": {
      "apiBaseUrl": "https://api-production-1d45.up.railway.app",
      "googleClientId": "",
      "sentryDsn": "",
      "sentryEnv": "production",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4246c823-c53c-4c9d-837c-04fe34f2323c"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "giwon1130",
    "updates": {
      "url": "https://u.expo.dev/4246c823-c53c-4c9d-837c-04fe34f2323c"
    }
  }
}

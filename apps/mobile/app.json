{
  "expo": {
    "name": "homefit",
    "slug": "homefit",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "homefit",
    "platforms": ["ios", "android"],
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "app.homefit.mobile",
      "supportsTablet": false
    },
    "android": {
      "package": "app.homefit.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications"
    ],
    "notification": {
      "iosDisplayInForeground": true
    },
    "extra": {
      "apiBaseUrl": "https://api-production-1d45.up.railway.app",
      "googleClientId": ""
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}

{
  "expo": {
    "name": "homefit",
    "slug": "homefit",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "homefit",
    "platforms": ["ios", "android"],
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "app.homefit.mobile",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.homefit.mobile",
      "versionCode": 1
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/PROJECT_ID_REPLACE"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications",
      "expo-apple-authentication"
    ],
    "notification": {
      "iosDisplayInForeground": true
    },
    "extra": {
      "apiBaseUrl": "https://api-production-1d45.up.railway.app",
      "googleClientId": "",
      "eas": {
        "projectId": "REPLACE_AFTER_eas_init"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}

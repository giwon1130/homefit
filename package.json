{
  "name": "homefit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev:web": "pnpm -F @homefit/web dev",
    "dev:mobile": "pnpm -F @homefit/mobile start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:up": "docker compose up -d db redis",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
